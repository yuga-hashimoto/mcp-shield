{
  "name": "mcp-shield",
  "version": "1.0.0",
  "description": "Detect and block Tool Poisoning attacks in MCP servers. Scans tool descriptions for hidden instructions, prompt injections, and data exfiltration attempts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-shield": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "security",
    "tool-poisoning",
    "prompt-injection",
    "model-context-protocol",
    "ai-safety",
    "llm-security"
  ],
  "author": "yuga-hashimoto",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
