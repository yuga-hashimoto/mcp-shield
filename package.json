{
  "name": "mcp-shield",
  "version": "1.0.0",
  "description": "Detect and block Tool Poisoning attacks in MCP servers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "mcp-shield": "dist/cli.js" },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp","security","tool-poisoning","prompt-injection","model-context-protocol","ai-safety","llm-security"],
  "author": "yuga-hashimoto",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "engines": { "node": ">=18.0.0" }
}
